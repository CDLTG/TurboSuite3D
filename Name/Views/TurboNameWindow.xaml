<Window
    x:Class="TurboSuite.Name.Views.TurboNameWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TurboName"
    Height="400" Width="420"
    MinHeight="400" MinWidth="380"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="12"
    ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="DisabledBgBrush" Color="#F0F0F0"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Assign Room Names section -->
        <GroupBox Grid.Row="0" Header="Assign Room Names" Padding="12,8">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Reads linked DWG files to extract room names and ceiling heights, assigns them to Room Region filled regions, and places TextNotes."/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Room Regions: " FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding RegionCount}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,2,0,0">
                    <TextBlock Text="CAD Room Entries: " FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CadEntryCount}"/>
                </StackPanel>
                <Button Content="Run" Width="80" HorizontalAlignment="Right" Margin="0,8,0,0"
                        Command="{Binding RunAssignCommand}" IsDefault="True"/>
            </StackPanel>
        </GroupBox>

        <Separator Grid.Row="2" Background="{StaticResource SeparatorBrush}"/>

        <!-- Generate Regions section (disabled — experimental, not yet reliable) -->
        <GroupBox Grid.Row="4" Header="Generate Regions" Padding="12,8" IsEnabled="False" Opacity="0.5">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="Gray" FontStyle="Italic"
                           Text="Under construction — auto-generate Room Region filled regions from linked CAD wall lines."/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                    <TextBlock Text="Wall Segments: " FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WallSegmentCount}"/>
                </StackPanel>
                <Button Content="Generate" Width="80" HorizontalAlignment="Right" Margin="0,8,0,0"
                        Command="{Binding RunGenerateCommand}"/>
            </StackPanel>
        </GroupBox>

        <!-- Close button -->
        <Button Grid.Row="6" Content="Close" Width="80" HorizontalAlignment="Right"
                Click="CloseButton_Click" IsCancel="True"/>
    </Grid>
</Window>
