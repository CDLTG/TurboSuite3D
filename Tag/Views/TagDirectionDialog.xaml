<Window
    x:Class="TurboSuite.Tag.Views.TagDirectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI" FontSize="12">

    <Border BorderBrush="#ABADB3" BorderThickness="1" Background="White"
            CornerRadius="0">
        <StackPanel>
            <!-- Custom title bar -->
            <DockPanel Margin="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="Tag Direction" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="10,7,0,0"/>
                <Button DockPanel.Dock="Right" Content="&#xD7;" FontSize="12"
                        Width="22" Height="22" Padding="0,-1,0,0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        Click="Close_Click"
                        BorderBrush="#ABADB3" BorderThickness="1"
                        Background="#F0F0F0" Foreground="#333333"
                        FontWeight="Bold" Cursor="Hand"/>
            </DockPanel>

            <!-- Content -->
            <StackPanel Margin="12,8,12,12">
                <TextBlock Text="Select tag placement direction:"
                           Margin="0,0,0,8"/>

                <StackPanel HorizontalAlignment="Stretch">
                    <Button Content="Up" Height="28" Margin="0,2"
                            Click="Up_Click"/>
                    <Button x:Name="DownButton" Content="Down" Height="28" Margin="0,2"
                            Click="Down_Click"/>
                    <Button x:Name="LeftButton" Content="Left" Height="28" Margin="0,2"
                            Click="Left_Click"/>
                    <Button x:Name="RightButton" Content="Right" Height="28" Margin="0,2"
                            Click="Right_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
