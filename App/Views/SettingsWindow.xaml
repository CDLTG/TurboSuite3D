<Window
    x:Class="TurboSuite.App.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TurboSuite Settings"
    Height="820" Width="500"
    MinHeight="420" MinWidth="400"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="11">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBlueBrush}" Padding="16,10">
            <TextBlock Text="TurboSuite Settings" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource FooterBgBrush}"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Button Content="Reset Defaults" HorizontalAlignment="Left"
                        Command="{Binding ResetDefaultsCommand}"
                        Padding="12,5" MinWidth="100"
                        Background="{StaticResource ButtonBgBrush}"
                        BorderBrush="{StaticResource ButtonBorderBrush}"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Padding="12,5" MinWidth="75" Margin="0,0,8,0"
                            Background="{StaticResource ButtonBgBrush}"
                            BorderBrush="{StaticResource ButtonBorderBrush}"/>
                    <Button Content="Cancel" IsCancel="True"
                            Padding="12,5" MinWidth="75"
                            Background="{StaticResource ButtonBgBrush}"
                            BorderBrush="{StaticResource ButtonBorderBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Configure which family names receive special routing behavior."
                           Foreground="#555555" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <GroupBox Header="Wall Sconce Families" Margin="0,0,0,10">
                    <StackPanel Margin="4">
                        <TextBlock Text="Families matched for wall sconce spline routing (one per line):"
                                   Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding WallSconceFamiliesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Height="95"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Receptacle Families" Margin="0,0,0,10">
                    <StackPanel Margin="4">
                        <TextBlock Text="Families matched for receptacle spline routing (one per line):"
                                   Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ReceptacleFamiliesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Height="95"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Vertical Families" Margin="0,0,0,10">
                    <StackPanel Margin="4">
                        <TextBlock Text="Lighting fixture families treated as wall-mounted for tag placement (one per line):"
                                   Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding VerticalFamiliesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Height="95"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Equipment Box Families" Margin="0,0,0,10">
                    <StackPanel Margin="4">
                        <TextBlock Text="Families matched for vertical (up/down) switchleg placement (one per line):"
                                   Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ElectricalVerticalFamiliesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Height="95"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
