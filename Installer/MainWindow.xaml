<Window x:Class="TurboSuiteInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TurboSuite Installer"
        Height="320" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="11">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBlueBrush}" Padding="16,10">
            <TextBlock Text="TurboSuite Installer" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource FooterBgBrush}"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Button Content="Uninstall" HorizontalAlignment="Left"
                        Command="{Binding UninstallCommand}"
                        Padding="12,5" MinWidth="75"
                        Background="{StaticResource ButtonBgBrush}"
                        BorderBrush="{StaticResource ButtonBorderBrush}"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="Install" Command="{Binding InstallCommand}"
                            Padding="12,5" MinWidth="75" Margin="0,0,8,0"
                            Background="{StaticResource ButtonBgBrush}"
                            BorderBrush="{StaticResource ButtonBorderBrush}"/>
                    <Button Content="Close" Command="{Binding CloseCommand}"
                            Padding="12,5" MinWidth="75"
                            Background="{StaticResource ButtonBgBrush}"
                            BorderBrush="{StaticResource ButtonBorderBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,16,16,8" VerticalAlignment="Top">
            <TextBlock Text="{Binding VersionText}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SourcePathText}" Foreground="#666666" FontSize="10"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,16"/>

            <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="20" Margin="0,0,0,12"/>

            <TextBlock Text="{Binding StatusText}" Foreground="#333333" Margin="0,0,0,8"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ResultText}" FontWeight="SemiBold" FontSize="12"
                       Foreground="{Binding ResultColor}" TextWrapping="Wrap"/>
        </StackPanel>
    </DockPanel>
</Window>
