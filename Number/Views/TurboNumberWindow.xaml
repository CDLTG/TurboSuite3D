<Window
    x:Class="TurboSuite.Number.Views.TurboNumberWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TurboNumber"
    Height="650" Width="900"
    MinHeight="400" MinWidth="500"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="11"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <!-- Brushes -->
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="ContentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>

        <!-- Revit Button Style -->
        <Style x:Key="RevitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#D9D9D9"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ContentBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Blue header bar -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBlueBrush}" Padding="15,10">
            <TextBlock Text="TurboNumber - Numbering Manager"
                       Foreground="White" FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <!-- Tab content -->
        <TabControl Grid.Row="1" Margin="8,6">
            <!-- Circuit Numbers Tab -->
            <TabItem Header="{Binding CircuitTab.TabHeader}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Panel selector + inline settings + Apply (left), Open Schedule (right) -->
                    <DockPanel Grid.Row="0" Margin="4,6,4,2">
                        <Button Command="{Binding CircuitTab.OpenScheduleCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26"
                                DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock>
                                <Run Text="Open Panel Schedule "/>
                                <Run Text="{Binding CircuitTab.SelectedPanel, Mode=OneWay}"/>
                            </TextBlock>
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Panel:" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding CircuitTab.Panels}"
                                      SelectedItem="{Binding CircuitTab.SelectedPanel}"
                                      MinWidth="80" Height="24" Margin="0,0,8,0"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                       Margin="4,2,12,2"/>

                            <TextBlock Text="Circuit Naming:" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding CircuitTab.CircuitNamingOptions}"
                                      SelectedItem="{Binding CircuitTab.SelectedPanelSettings.CircuitNaming}"
                                      MinWidth="90" Height="24" Margin="0,0,8,0"/>

                            <TextBlock Text="Prefix:" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding CircuitTab.SelectedPanelSettings.CircuitPrefix, UpdateSourceTrigger=PropertyChanged}"
                                     Width="40" Height="24" VerticalContentAlignment="Center" Padding="3,0" Margin="0,0,8,0"/>

                            <TextBlock Text="Separator:" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding CircuitTab.SelectedPanelSettings.CircuitPrefixSeparator, UpdateSourceTrigger=PropertyChanged}"
                                     Width="40" Height="24" VerticalContentAlignment="Center" Padding="3,0" Margin="0,0,8,0"/>

                            <Button Content="Apply" Command="{Binding CircuitTab.ApplyCommand}"
                                    Style="{StaticResource RevitButtonStyle}" Height="26"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Row 1: Move and assign buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,2,4,4"
                                VerticalAlignment="Center">
                        <Button Content="Move Up" Command="{Binding CircuitTab.MoveUpCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26" Margin="0,0,4,0"/>
                        <Button Content="Move Down" Command="{Binding CircuitTab.MoveDownCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26"/>

                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="8,2,8,2"/>

                        <Button Content="Assign Spare" Command="{Binding CircuitTab.AssignSpareCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26" Margin="0,0,4,0"/>
                        <Button Content="Assign Space" Command="{Binding CircuitTab.AssignSpaceCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26" Margin="0,0,4,0"/>
                        <Button Content="Remove" Command="{Binding CircuitTab.RemoveSpareSpaceCommand}"
                                Style="{StaticResource RevitButtonStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Row 2: Two-column content area -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Panel slots DataGrid -->
                        <DataGrid Grid.Column="0" ItemsSource="{Binding CircuitTab.Rows}"
                                  SelectedItem="{Binding CircuitTab.SelectedRow}"
                                  SelectionChanged="CircuitDataGrid_SelectionChanged"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserReorderColumns="False" CanUserSortColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource SeparatorBrush}"
                                  BorderThickness="1" BorderBrush="{StaticResource SeparatorBrush}"
                                  Margin="4,0,2,0">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SlotType}" Value="Spare">
                                            <Setter Property="Background" Value="#FFFFDD"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SlotType}" Value="Space">
                                            <Setter Property="Background" Value="#FFFFDD"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Slot" Binding="{Binding SlotNumber}" Width="50"/>
                                <DataGridTextColumn Header="Load Name" Binding="{Binding LoadName}" Width="*"/>
                                <DataGridTextColumn Header="Number" Binding="{Binding Value}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Right: All circuits summary -->
                        <Grid Grid.Column="1" Width="158">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0" ItemsSource="{Binding CircuitTab.AllCircuitRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      CanUserReorderColumns="False" CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource SeparatorBrush}"
                                      AlternatingRowBackground="#F9F9F9"
                                      BorderThickness="1" BorderBrush="{StaticResource SeparatorBrush}"
                                      Margin="2,0,4,0">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Number" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                                                    <Setter Property="Background" Value="#FFDDDD"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Margin="2,0"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Panel" Binding="{Binding Panel}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="1" Margin="6,4,4,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                       Text="{Binding CircuitTab.AllCircuitCount, StringFormat='Total: {0} circuits'}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Keypads Tab -->
            <TabItem Header="{Binding KeypadTab.TabHeader}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Room Order Sidebar -->
                    <Border Grid.Column="0" Width="160" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,1,0"
                            Background="{StaticResource FooterBgBrush}"
                            Visibility="{Binding KeypadTab.IsSidebarVisible, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Room Order" FontWeight="SemiBold" Margin="8,8,8,4"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button DockPanel.Dock="Bottom" Content="Reset" Margin="4,4"
                                    Command="{Binding KeypadTab.ResetRoomOrderCommand}"
                                    Style="{StaticResource RevitButtonStyle}" Height="24"/>

                            <ListBox x:Name="RoomOrderListBox" Margin="4,0,4,4"
                                     ItemsSource="{Binding KeypadTab.RoomOrder}"
                                     AllowDrop="True"
                                     PreviewMouseLeftButtonDown="RoomOrderListBox_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="RoomOrderListBox_PreviewMouseMove"
                                     DragOver="RoomOrderListBox_DragOver"
                                     DragLeave="RoomOrderListBox_DragLeave"
                                     Drop="RoomOrderListBox_Drop"
                                     BorderThickness="0" Background="Transparent"/>
                        </DockPanel>
                    </Border>

                    <!-- Main Content -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="4,6">
                            <Button Content="Room Order" Command="{Binding KeypadTab.ToggleSidebarCommand}"
                                    Height="26" HorizontalAlignment="Left">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RevitButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding KeypadTab.IsSidebarVisible}" Value="True">
                                                    <Setter Property="Background" Value="#DDEAF6"/>
                                                    <Setter Property="BorderBrush" Value="#9BBDDC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding KeypadTab.ToggleCascadeCommand}"
                                        Width="110" Height="26" Margin="0,0,8,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RevitButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding KeypadTab.IsCascadeEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#DDEAF6"/>
                                                    <Setter Property="BorderBrush" Value="#9BBDDC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Mode: Manual"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KeypadTab.IsCascadeEnabled}" Value="True">
                                                        <Setter Property="Text" Value="Mode: Auto"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                                <Button Content="Auto-Number" Command="{Binding KeypadTab.AutoNumberCommand}"
                                        Style="{StaticResource RevitButtonStyle}" Width="110" Height="26"/>
                            </StackPanel>
                        </Grid>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding KeypadTab.Rows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="{Binding KeypadTab.CanUserSortColumns}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource SeparatorBrush}"
                                  AlternatingRowBackground="#F9F9F9"
                                  BorderThickness="1" BorderBrush="{StaticResource SeparatorBrush}"
                                  Margin="4,0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="LockIcon" Text="&#x1F512;" FontSize="9" Margin="4,0,0,0"
                                                               VerticalAlignment="Center" Foreground="#555555" Visibility="Collapsed"/>
                                                </StackPanel>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.KeypadTab.CanUserSortColumns, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                        <Setter TargetName="LockIcon" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.KeypadTab.CanUserSortColumns, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Model" Binding="{Binding DisplayLabel}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Room Number" Binding="{Binding RoomNumber}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Room Name" Binding="{Binding RoomName}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Number" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <DockPanel Grid.Row="2" Margin="4,6">
<Button Content="Apply" Command="{Binding KeypadTab.ApplyCommand}"
                                    Style="{StaticResource RevitButtonStyle}" Width="80" Height="28"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Power Supplies Tab -->
            <TabItem Header="{Binding PowerSupplyTab.TabHeader}">
                <Grid Focusable="True" FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="4,6">
                        <TextBlock Text="Prefix:" VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding PowerSupplyTab.Prefix, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" Height="22" VerticalContentAlignment="Center" Padding="3,0"/>
                        <TextBlock Text="Suffix:" VerticalAlignment="Center" Margin="12,0,4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding PowerSupplyTab.Suffix, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" Height="22" VerticalContentAlignment="Center" Padding="3,0"/>
                        <Button Command="{Binding PowerSupplyTab.ToggleCascadeCommand}"
                                Width="110" Height="26" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RevitButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PowerSupplyTab.IsCascadeEnabled}" Value="True">
                                            <Setter Property="Background" Value="#DDEAF6"/>
                                            <Setter Property="BorderBrush" Value="#9BBDDC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Mode: Manual"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PowerSupplyTab.IsCascadeEnabled}" Value="True">
                                                <Setter Property="Text" Value="Mode: Auto"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Content="Auto-Number" Command="{Binding PowerSupplyTab.AutoNumberCommand}"
                                Style="{StaticResource RevitButtonStyle}" Width="110" Height="26" Margin="8,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PowerSupplyTab.Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserSortColumns="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource SeparatorBrush}"
                              AlternatingRowBackground="#F9F9F9"
                              BorderThickness="1" BorderBrush="{StaticResource SeparatorBrush}"
                              Margin="4,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model" Binding="{Binding DisplayLabel}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Load Name" Binding="{Binding LoadName}" Width="235" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Circuit" Binding="{Binding CircuitNumber}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Number" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="4,6">
<Button Content="Apply" Command="{Binding PowerSupplyTab.ApplyCommand}"
                                Style="{StaticResource RevitButtonStyle}" Width="80" Height="28"
                                DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer bar -->
        <Border Grid.Row="2" Background="{StaticResource FooterBgBrush}" Padding="12,7"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Close" Click="CloseButton_Click"
                        Style="{StaticResource RevitButtonStyle}"
                        Width="80" Height="28"
                        DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
