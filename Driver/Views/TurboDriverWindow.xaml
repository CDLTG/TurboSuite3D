<Window
    x:Class="TurboSuite.Driver.Views.TurboDriverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:TurboSuite.Driver.Views"
    Title="TurboDriver"
    Height="850" Width="500"
    MinHeight="400" MinWidth="650"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="11"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Converters -->
        <local:FeetInchesConverter x:Key="FeetInchesConverter"/>
        <local:FlattenDevicesConverter x:Key="FlattenDevicesConverter"/>
        <local:FamilyTypeDisplayConverter x:Key="FamilyTypeDisplayConverter"/>
        <local:SubDriverHeaderConverter x:Key="SubDriverHeaderConverter"/>
        <local:SegmentDisplayConverter x:Key="SegmentDisplayConverter"/>
        <local:IsRecommendedTypeConverter x:Key="IsRecommendedTypeConverter"/>

        <!-- Brushes -->
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="ContentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SectionBgBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D5D5D5"/>
        <SolidColorBrush x:Key="TableHeaderBgBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="AltRowBgBrush" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>
        <SolidColorBrush x:Key="CircuitHeaderBgBrush" Color="#D0DBE9"/>
        <SolidColorBrush x:Key="SelectionBgBrush" Color="#EDF2F9"/>
        <SolidColorBrush x:Key="SelectionBorderBrush" Color="#4A78B0"/>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- Table Header Style -->
        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Table Cell Style -->
        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Revit Button Style -->
        <Style x:Key="RevitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Circuit Expander Style -->
        <Style x:Key="CircuitExpanderStyle" TargetType="Expander">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderToggle"
                                              DockPanel.Dock="Top"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="headerBorder"
                                                    Background="{StaticResource CircuitHeaderBgBrush}"
                                                    Padding="10,6">
                                                <DockPanel>
                                                    <Path x:Name="Arrow"
                                                          DockPanel.Dock="Left"
                                                          Data="M 0 0 L 5 4 L 10 0"
                                                          Stroke="{StaticResource TextSecondaryBrush}"
                                                          StrokeThickness="1.5"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <ContentPresenter/>
                                                </DockPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="headerBorder" Property="Background" Value="#C2CFE0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpanderContent"
                                                  DockPanel.Dock="Bottom"
                                                  Visibility="Collapsed"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sub-section Expander Style (gray header for inner expanders) -->
        <Style x:Key="SubExpanderStyle" TargetType="Expander" BasedOn="{StaticResource CircuitExpanderStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderToggle"
                                              DockPanel.Dock="Top"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="headerBorder"
                                                    Background="{StaticResource SectionBgBrush}"
                                                    Padding="10,6">
                                                <DockPanel>
                                                    <Path x:Name="Arrow"
                                                          DockPanel.Dock="Left"
                                                          Data="M 0 0 L 5 4 L 10 0"
                                                          Stroke="{StaticResource TextSecondaryBrush}"
                                                          StrokeThickness="1.5"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <ContentPresenter/>
                                                </DockPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="headerBorder" Property="Background" Value="#E8E8E8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpanderContent"
                                                  DockPanel.Dock="Bottom"
                                                  Visibility="Collapsed"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ContentBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Blue header bar -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBlueBrush}" Padding="15,10">
            <TextBlock Text="TurboDriver - Power Supply Selection Manager"
                       Foreground="White" FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <!-- Content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,6">
            <ItemsControl ItemsSource="{Binding Circuits}" Margin="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Circuit Card as Expander -->
                        <Expander Style="{StaticResource CircuitExpanderStyle}">
                            <!-- Header: Circuit summary line -->
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CircuitNumber, StringFormat='Circuit: {0}'}"
                                               FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text=" | " Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LoadName}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" | " Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LoadClassificationAbbreviation}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" | " Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ApparentPower, StringFormat='{}{0:F1} W'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" | " Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Panel}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>

                            <!-- Content: Fixtures, Driver, Devices -->
                            <Border Padding="10,6" Background="{StaticResource ContentBgBrush}">
                                <StackPanel>

                                    <!-- === POWER SUPPLY SELECTION === -->
                                    <TextBlock Text="Select Power Supplies:"
                                               FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource HeaderBlueBrush}"
                                               Margin="0,2,0,4"/>
                                    <Border BorderBrush="{StaticResource SelectionBorderBrush}" BorderThickness="1" CornerRadius="2"
                                            Background="{StaticResource SelectionBgBrush}" Padding="10,6">
                                        <ItemsControl ItemsSource="{Binding DeviceGroups, Converter={StaticResource FlattenDevicesConverter}}"
                                                      Grid.IsSharedSizeScope="True">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="SwitchIDCol"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding SwitchID, StringFormat='{}{0}:'}"
                                                                   Style="{StaticResource ValueStyle}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Margin="0,0,10,0"/>
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding AvailableFamilyTypes}"
                                                                  SelectedItem="{Binding SelectedFamilyType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  MinWidth="350" HorizontalAlignment="Left"
                                                                  Padding="4,3">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock>
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource FamilyTypeDisplayConverter}">
                                                                                <Binding Path="Name"/>
                                                                                <Binding/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Value="True">
                                                                                        <DataTrigger.Binding>
                                                                                            <MultiBinding Converter="{StaticResource IsRecommendedTypeConverter}">
                                                                                                <Binding/>
                                                                                                <Binding Path="DataContext.RecommendedFamilyTypeId"
                                                                                                         RelativeSource="{RelativeSource AncestorType=ComboBox}"/>
                                                                                            </MultiBinding>
                                                                                        </DataTrigger.Binding>
                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                        <Setter Property="Foreground" Value="{StaticResource HeaderBlueBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- === RECOMMENDED DRIVER === -->
                                    <Expander Style="{StaticResource SubExpanderStyle}" IsExpanded="False" Margin="0,8,0,5">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Recommended Power Supplies &#x2192; "
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DriverRecommendation.DisplayText,
                                                                  TargetNullValue='No Linear Power data available',
                                                                  FallbackValue='No Linear Power data available'}"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDriverMatch}" Value="False">
                                                                    <Setter Property="Foreground" Value="Red"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Expander.Header>
                                        <Border Padding="10,8"
                                                Background="{StaticResource SectionBgBrush}">
                                            <StackPanel>
                                                <!-- Warning message for no-match case -->
                                                <TextBlock Text="{Binding DriverWarning}"
                                                           Foreground="Red" FontWeight="SemiBold"
                                                           Margin="0,0,0,6" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DriverWarning}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ItemsControl ItemsSource="{Binding DriverRecommendation.SubDriverAssignments}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="0,1,0,3">
                                                                <TextBlock Text="{Binding Converter={StaticResource SubDriverHeaderConverter}}"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                <ItemsControl ItemsSource="{Binding Segments}" Margin="16,0,0,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource SegmentDisplayConverter}}"
                                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Expander>

                                    <!-- === LIGHTING FIXTURES === -->
                                    <Expander Style="{StaticResource SubExpanderStyle}" IsExpanded="False" Margin="0,0,0,5">
                                        <Expander.Header>
                                            <TextBlock Text="Lighting Fixtures" FontWeight="SemiBold"/>
                                        </Expander.Header>
                                        <StackPanel Grid.IsSharedSizeScope="True">
                                            <!-- Column headers -->
                                            <Grid Background="{StaticResource TableHeaderBgBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureQtyCol"/>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureTypeCol"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Qty" Style="{StaticResource TableHeaderStyle}" TextAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Types" Style="{StaticResource TableHeaderStyle}" TextAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Comments" Style="{StaticResource TableHeaderStyle}"/>
                                                <TextBlock Grid.Column="3" Text="Lengths" Style="{StaticResource TableHeaderStyle}"/>
                                            </Grid>

                                            <!-- Fixture rows with alternating backgrounds -->
                                            <ListBox ItemsSource="{Binding GroupedFixtures}"
                                                     AlternationCount="2"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                     PreviewMouseWheel="FixtureList_PreviewMouseWheel">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Focusable" Value="False"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="Bd" Background="Transparent" Padding="0">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#F9F9F9"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureQtyCol"/>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureTypeCol"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Quantity}" Style="{StaticResource TableCellStyle}" TextAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TypeMark}" Style="{StaticResource TableCellStyle}" TextAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Comments}" Style="{StaticResource TableCellStyle}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding LinearLength, Converter={StaticResource FeetInchesConverter}}" Style="{StaticResource TableCellStyle}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- Totals row -->
                                            <Grid Background="{StaticResource FooterBgBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureQtyCol"/>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FixtureTypeCol"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TotalFixtureCount}" FontWeight="SemiBold" Style="{StaticResource TableCellStyle}" TextAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="2" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding TotalLinearLength, Converter={StaticResource FeetInchesConverter}}" FontWeight="SemiBold" Style="{StaticResource TableCellStyle}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Expander>

                                </StackPanel>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer bar -->
        <Border Grid.Row="2" Background="{StaticResource FooterBgBrush}" Padding="12,7"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Circuits.Count, StringFormat='Total Circuits: {0}'}"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="  |  " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalPowerSupplies, StringFormat='Total Power Supplies: {0}'}"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <Button Content="Close" Click="CloseButton_Click"
                        Style="{StaticResource RevitButtonStyle}"
                        Width="80" Height="28"
                        DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
