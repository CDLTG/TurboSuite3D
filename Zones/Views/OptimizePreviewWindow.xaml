<Window
    x:Class="TurboSuite.Zones.Views.OptimizePreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:TurboSuite.Zones.Views"
    Title="Optimize Panel Distribution"
    Height="520" Width="620"
    MinHeight="300" MinWidth="400"
    WindowStartupLocation="CenterOwner"
    FontFamily="Segoe UI" FontSize="11"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:DimmingTypeToColorConverter x:Key="DimmingTypeToColor"/>
        <local:BoolToRedForegroundConverter x:Key="BoolToRedForeground"/>

        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>
        <SolidColorBrush x:Key="SavingsBrush" Color="#2E7D32"/>

        <Style x:Key="PreviewButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#D9D9D9"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBlueBrush}" Padding="15,8">
            <TextBlock Text="Optimize Panel Distribution" Foreground="White"
                       FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
            <StackPanel>
                <!-- No changes message -->
                <TextBlock Text="Panels are already optimally distributed. No changes are needed."
                           Visibility="{Binding NoChanges, Converter={StaticResource BoolToVisibility}}"
                           FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>

                <!-- Changes content -->
                <StackPanel Visibility="{Binding HasChanges, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="The following circuit moves will optimize module distribution:"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                    <!-- Per-location summaries -->
                    <ItemsControl ItemsSource="{Binding LocationSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,12">
                                    <!-- Location header -->
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock FontWeight="SemiBold" FontSize="12">
                                            <Run Text="Location "/>
                                            <Run Text="{Binding LocationNumber, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   Visibility="{Binding HasSavings, Converter={StaticResource BoolToVisibility}}"
                                                   Foreground="{StaticResource SavingsBrush}" FontWeight="SemiBold">
                                            <Run Text="-"/>
                                            <Run Text="{Binding ModuleSavings, Mode=OneWay}"/>
                                            <Run Text=" module(s)"/>
                                        </TextBlock>
                                    </DockPanel>

                                    <!-- Before / After columns -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Before -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Before" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                            <ItemsControl ItemsSource="{Binding Before}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderThickness="1" BorderBrush="#DDDDDD"
                                                                CornerRadius="3" Margin="0,1" Padding="6,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding PanelName}"
                                                                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                                <!-- Type breakdown -->
                                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Types}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="{Binding DimmingType, Converter={StaticResource DimmingTypeToColor}}"
                                                                                    CornerRadius="2" Padding="3,0" Margin="1,0">
                                                                                <TextBlock FontSize="9" Foreground="White">
                                                                                    <Run Text="{Binding CircuitCount, Mode=OneWay}"/>
                                                                                </TextBlock>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Grid.Column="2"
                                                                           Foreground="{Binding IsOverCapacity, Converter={StaticResource BoolToRedForeground}}">
                                                                    <Run Text="{Binding TotalModules, Mode=OneWay}"/>
                                                                    <Run Text="/"/>
                                                                    <Run Text="{Binding PanelCapacity, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Separator -->
                                        <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="16"
                                                   VerticalAlignment="Center" Margin="8,12,8,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <!-- After -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="After" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                            <ItemsControl ItemsSource="{Binding After}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderThickness="1" BorderBrush="#DDDDDD"
                                                                CornerRadius="3" Margin="0,1" Padding="6,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding PanelName}"
                                                                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Types}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="{Binding DimmingType, Converter={StaticResource DimmingTypeToColor}}"
                                                                                    CornerRadius="2" Padding="3,0" Margin="1,0">
                                                                                <TextBlock FontSize="9" Foreground="White">
                                                                                    <Run Text="{Binding CircuitCount, Mode=OneWay}"/>
                                                                                </TextBlock>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Grid.Column="2"
                                                                           Foreground="{Binding IsOverCapacity, Converter={StaticResource BoolToRedForeground}}">
                                                                    <Run Text="{Binding TotalModules, Mode=OneWay}"/>
                                                                    <Run Text="/"/>
                                                                    <Run Text="{Binding PanelCapacity, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Move list -->
                                    <TextBlock Text="Moves:" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,1"/>
                                    <ItemsControl ItemsSource="{Binding MovesInLocation}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="9" Foreground="#444444" Margin="8,0,0,0">
                                                    <Run Text="{Binding CircuitNumber, Mode=OneWay}"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding DimmingType, Mode=OneWay}"/>
                                                    <Run Text=")  "/>
                                                    <Run Text="{Binding FromPanel, Mode=OneWay}"/>
                                                    <Run Text=" &#x2192; "/>
                                                    <Run Text="{Binding ToPanel, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Summary -->
                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold">
                        <Run Text="{Binding TotalMoves, Mode=OneWay}"/>
                        <Run Text=" circuit(s) will be moved."/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource FooterBgBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="8,6">
            <DockPanel>
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource PreviewButtonStyle}" Height="28"
                        DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <Button Content="Confirm" Click="Confirm_Click"
                        IsEnabled="{Binding HasChanges}"
                        Style="{StaticResource PreviewButtonStyle}" Height="28"
                        Background="{StaticResource HeaderBlueBrush}" Foreground="White"
                        DockPanel.Dock="Right"/>
                <TextBlock/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
