<Window
    x:Class="TurboSuite.Cuts.Views.TurboCutsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TurboCuts"
    Height="750" Width="750"
    MinHeight="400" MinWidth="550"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="11"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <SolidColorBrush x:Key="HeaderBlueBrush" Color="#2B579A"/>
        <SolidColorBrush x:Key="FooterBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ACACAC"/>

        <!-- Faint selection highlight and lighter grid lines -->
        <Style TargetType="DataGridRow">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D0D8E8"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E0E4EC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
            </Style.Resources>
        </Style>

        <!-- Single-click checkbox editing -->
        <Style x:Key="SingleClickCheckBoxColumn" TargetType="DataGridCell">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDown"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBlueBrush}" Padding="16,10">
            <TextBlock Text="TurboCuts — Cut Sheet Generator" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource FooterBgBrush}" Padding="12,8"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Generate" Command="{Binding GenerateCommand}" Width="90" Height="28" Margin="0,0,8,0"
                            Background="{StaticResource HeaderBlueBrush}" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0"/>
                    <Button Content="Close" Click="CloseButton_Click" Width="70" Height="28"
                            Background="{StaticResource ButtonBgBrush}" BorderBrush="{StaticResource ButtonBorderBrush}"/>
                </StackPanel>
                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="4,0,12,0"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <DockPanel Margin="16,12">
            <!-- Settings docked to top -->
            <GroupBox DockPanel.Dock="Top" Header="Settings" Margin="0,0,0,12">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Logo:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding LogoFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="0" Grid.Column="1" Margin="0,0,4,4" Height="24" VerticalContentAlignment="Center"/>
                        <Button Content="Browse..." Command="{Binding BrowseLogoCommand}"
                                Grid.Row="0" Grid.Column="2" Width="70" Height="24" Margin="0,0,0,4"/>

                        <TextBlock Text="Address:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,4" Height="24"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="Phone:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,4" Height="24"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="Website:" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0"/>
                        <TextBox Text="{Binding CompanyWebsite, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,4" Height="24"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="Date:" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0"/>
                        <DatePicker SelectedDate="{Binding HeaderDate, UpdateSourceTrigger=PropertyChanged}"
                                    Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Height="24"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="#ABADB3" BorderThickness="1"/>
                    </Grid>
            </GroupBox>

            <!-- Progress bar docked to bottom -->
            <ProgressBar DockPanel.Dock="Bottom" Value="{Binding Progress}" Height="18" Margin="0,4,0,0"
                         Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Fixture Types fills remaining space -->
            <GroupBox Header="Fixture Types" Margin="0,0,0,0">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Select All" Command="{Binding SelectAllCommand}" Width="75" Height="24"
                                    Background="{StaticResource ButtonBgBrush}" BorderBrush="{StaticResource ButtonBorderBrush}"
                                    Margin="0,0,6,0"/>
                            <Button Content="Deselect All" Command="{Binding DeselectAllCommand}" Width="85" Height="24"
                                    Background="{StaticResource ButtonBgBrush}" BorderBrush="{StaticResource ButtonBorderBrush}"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Fixtures}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserSortColumns="False"
                                  IsReadOnly="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  BorderThickness="1" BorderBrush="#CCCCCC"
                                  MinHeight="150">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="35"
                                                        CellStyle="{StaticResource SingleClickCheckBoxColumn}">
                                    <DataGridCheckBoxColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.HeaderStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeMark}" Width="45" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Family Name" Binding="{Binding FamilyName}" Width="200" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="PDF Source" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="✕" Width="18" Height="18" Margin="2,0,0,0"
                                                        FontSize="9" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                        Command="{Binding DataContext.ClearLocalPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding HasLocalPdf, Converter={StaticResource BoolToVisibility}}"/>
                                                <Button DockPanel.Dock="Right" Content="..." Width="18" Height="18" Margin="2,0,0,0"
                                                        FontSize="9" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                        Command="{Binding DataContext.BrowseLocalPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding DataSheetUrl}"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasLocalPdf}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding LocalPdfPath}"/>
                                                                    <Setter Property="Foreground" Value="#1A7F37"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DockPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
            </GroupBox>
        </DockPanel>
    </DockPanel>
</Window>
